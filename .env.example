# Local server port (8081 to coexist with AzureGanttOps on 8080)
PORT=8081

# Optional: personal access token for Azure DevOps.
# If not set, the app falls back to Azure CLI access token flow.
# ADO_PAT=
# AZURE_DEVOPS_EXT_PAT=

# Logging and writeback behavior
ADO_VERBOSE_LOGS=1
ADO_WRITE_ENABLED=1
